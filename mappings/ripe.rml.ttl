    void:exampleResource :map_inspectAI_000.
:map_inspectAI_000 rml:logicalSource :source_000.
:source_000 a rml:LogicalSource;
    rml:source "assessments/assessments_yarrrml.json";
    rml:iterator "$.assessments[0]";
